{
  "name": "@waves/waves-browser-bus",
  "version": "0.2.7",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git@github.com:wavesplatform/waves-browser-bus.git"
  },
  "bugs": {
    "url": "https://github.com/wavesplatform/waves-browser-bus/issues"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "esbuild": "^0.28.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3",
    "vite": "^8.0.9"
  },
  "files": [
    "dist"
  ],
  "jest": {
    "collectCoverage": true,
    "testEnvironment": "jsdom",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/test/"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    },
    "testMatch": [
      "**/test/*test.+(ts)"
    ]
  },
  "scripts": {
    "patch": "npm version patch && npm publish && git push",
    "build": "tsc --build ./ && npm run _build-full",
    "test": "jest",
    "_build-full": "vite build && vite build --mode min"
  },
  "dependencies": {
    "@types/node": "^25.6.0"
  }
}
