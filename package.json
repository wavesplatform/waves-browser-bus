{
  "name": "@waves/waves-browser-bus",
  "version": "0.2.8",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git@github.com:wavesplatform/waves-browser-bus.git"
  },
  "bugs": {
    "url": "https://github.com/wavesplatform/waves-browser-bus/issues"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "esbuild": "^0.28.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "files": [
    "dist"
  ],
  "jest": {
    "collectCoverage": true,
    "testEnvironment": "jsdom",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/test/"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": "test/tsconfig.json"
        }
      ]
    },
    "testMatch": [
      "**/test/*test.+(ts)"
    ]
  },
  "scripts": {
    "build": "tsc --build ./ && npm run _build-full",
    "test": "jest",
    "_build-full": "vite build && vite build --mode min",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@types/node": "^25.9.2"
  },
  "overrides": {
    "glob": "^13.0.6",
    "jsdom": "^29.1.1",
    "test-exclude": "^7.0.1"
  }
}
